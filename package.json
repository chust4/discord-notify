  "version": "1.4.1",
  "description": "Web panel + Discord bot for notifying about new videos and live streams from YouTube, TikTok, Twitch and Kick.",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
