# ============================================================================
#  Discord Notify — przykładowa konfiguracja
#  Skopiuj do .env (lokalnie) LUB wpisz te zmienne w Portainerze:
#  Stacks → (twój stack) → sekcja "Environment variables".
#
#  NIGDY nie commituj prawdziwych sekretów. Plik .env jest w .gitignore.
# ============================================================================

# ---------- Sieć / aplikacja ----------
# Port na hoście (NAS). Aplikacja będzie pod http://<IP-NAS>:APP_PORT
APP_PORT=8092
APP_NAME=Discord Notify

# Ścieżka na NAS, w której zapiszą się baza danych i logi (bind mount).
# Domyślnie folder, który podałeś. Zmień, jeśli używasz innej lokalizacji.
DATA_PATH=/volume1/docker/discord-notify-bot

# ---------- Logowanie ----------
# Poziom logów: debug | info | warn | error
LOG_LEVEL=info
# DEBUG=true włącza najbardziej szczegółowe logi (równoważne LOG_LEVEL=debug)
DEBUG=false
# Czy zapisywać logi do plików (oprócz stdout/stderr widocznych w Portainerze)
LOG_TO_FILE=true
# Automatyczna rotacja: pliki logów starsze niż tyle dni są kasowane
LOG_RETENTION_DAYS=7

# ---------- Sprawdzanie (polling) ----------
# Co ile sekund sprawdzać nowe filmy/live (min. 60). 300 = co 5 minut.
POLL_INTERVAL_SECONDS=300
# Granica YouTube Shorts: film krótszy niż tyle sekund = Short.
YOUTUBE_SHORT_MAX_SECONDS=180
# Wgrać przykładowe dane demo przy pierwszym starcie (true/false)
SEED_DEMO_DATA=false

# ---------- Discord (WYMAGANE, aby bot działał) ----------
# Token bota z https://discord.com/developers/applications -> Bot -> Reset Token
DISCORD_TOKEN=
# Application (Client) ID z zakładki "General Information"
DISCORD_CLIENT_ID=
# Opcjonalnie: ID serwerów autoryzowanych z góry (po przecinku).
# Inne serwery autoryzujesz w panelu w sekcji "Serwery".
DISCORD_AUTHORIZED_GUILD_IDS=
# Opcjonalnie: ID użytkowników Discord mogących używać komend administracyjnych
DISCORD_OWNER_IDS=

# ---------- Klucze API platform (OPCJONALNE) ----------
# YouTube Data API v3 — potrzebny do avatarów oraz rozróżniania Shorts/live.
# https://console.cloud.google.com/  ->  YouTube Data API v3  ->  API key
YOUTUBE_API_KEY=
# Twitch — wymagane do wykrywania live na Twitch.
# https://dev.twitch.tv/console/apps  ->  Register Your Application
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# (TikTok i Kick nie wymagają kluczy — działają best-effort bez API.)

# ---------- Ochrona panelu (OPCJONALNE, zalecane w sieci LAN) ----------
# Jeśli ustawisz oba, panel poprosi o login/hasło (HTTP Basic Auth).
PANEL_USER=
PANEL_PASSWORD=
